model User {
    id            String         @id @default(uuid())
    name          String?
    lastName      String?
    email         String         @unique
    password      String
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt
    refreshTokens RefreshToken[]
    problems      Problem[]

    @@map("users")
}

model RefreshToken {
    id        String   @id @default(uuid())
    token     String   @unique
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    expiresAt DateTime
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([userId])
    @@index([expiresAt])
    @@map("refresh_tokens")
}
