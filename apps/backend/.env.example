# -----------------------------
# Runtime
# -----------------------------
# Allowed examples: development | test | production
NODE_ENV=development

# Backend server port
PORT=3000

# -----------------------------
# Database (Prisma / Postgres)
# -----------------------------
# Format:
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local example:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/code_evaluation_platform

# -----------------------------
# JWT Authentication
# -----------------------------
# Use long, random secrets in real environments.
# Generate one with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret

# Expiration values are in seconds.
# 900 = 15 minutes
JWT_ACCESS_EXPIRES_IN=900
# 604800 = 7 days
JWT_REFRESH_EXPIRES_IN=604800

# -----------------------------
# CORS / Frontend
# -----------------------------
# Frontend app origin
FRONTEND_URL=http://localhost:5173
